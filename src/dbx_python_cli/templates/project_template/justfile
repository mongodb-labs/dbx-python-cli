# https://just.systems

default:
    echo 'Hello, world!'

[group('django')]
django-open:
    open http://localhost:8000
alias o := django-open

[group('django')]
django-serve:
    DJANGO_SETTINGS_MODULE={{ project_name }}.settings.{{ project_name }} python manage.py runserver

[group('django')]
django-migrate:
    python manage.py migrate
alias m := django-migrate

[group('django')]
django-makemigrations:
    python manage.py makemigrations taggit wagtailadmin wagtailcore wagtaildocs wagtailembeds wagtailforms wagtailimages wagtailredirects wagtailsearch wagtailusers
alias mm := django-makemigrations

[group('django')]
django-drop-mongo:
    #!/usr/bin/env sh
    if [ -n "$MONGODB_URI" ]; then
        DB_NAME=$(python -c "from urllib.parse import urlparse; import os; r=urlparse(os.environ['MONGODB_URI']); n=r.path.lstrip('/').split('?')[0]; print(n if n else '{{ project_name }}')")
        mongosh "$MONGODB_URI" --eval "db.getSiblingDB('$DB_NAME').dropDatabase()"
    else
        mongosh --eval "db.getSiblingDB('{{ project_name }}').dropDatabase()"
    fi

[group('django')]
django-drop-postgres:
    psql -U postgres -c "DROP DATABASE IF EXISTS {{ project_name }}; CREATE DATABASE {{ project_name }};"

[group('django')]
django-drop: django-drop-mongo
alias d := django-drop

# Create Django superuser (admin/admin)
[group('django')]
django-create-superuser:
    export DJANGO_SUPERUSER_PASSWORD=admin && python manage.py createsuperuser --noinput --username=admin --email=admin@example.com
alias su := django-create-superuser

[group('npm')]
npm-install:
    cd frontend && npm install

[group('npm')]
npm-serve:
    cd frontend && npm run watch &

[group('python')]
pip-install:
    python -m pip install --upgrade pip
    python -m pip install -e .
alias i := pip-install

# Run migrations and create Wagtail initial data (root page, home, site, superuser)
[group('django')]
django-setup:
    #!/usr/bin/env sh
    export DJANGO_SETTINGS_MODULE={{ project_name }}.settings.{{ project_name }}
    python manage.py migrate
    python -c "
import os, django
os.environ.setdefault('DJANGO_SETTINGS_MODULE', '{{ project_name }}.settings.{{ project_name }}')
django.setup()
try:
    from wagtail.models import Page
    if not Page.objects.filter(depth=1).exists():
        from django.conf import settings as s
        from django.contrib.contenttypes.models import ContentType
        from wagtail.models import Locale, Site
        lang = (getattr(s, 'LANGUAGE_CODE', 'en') or 'en').split('-')[0][:2]
        locale, _ = Locale.objects.get_or_create(language_code=lang)
        ct, _ = ContentType.objects.get_or_create(app_label='wagtailcore', model='page')
        root = Page.add_root(title='Root', slug='root', content_type=ct, locale=locale)
        home = root.add_child(title='Home', slug='home', content_type=ct, locale=locale)
        if not Site.objects.exists():
            Site.objects.create(hostname='localhost', root_page=home, is_default_site=True)
        print('Wagtail root page and site created.')
except ImportError:
    pass
"
    export DJANGO_SUPERUSER_PASSWORD=admin && python manage.py createsuperuser --noinput --username=admin --email=admin@example.com || true
alias setup := django-setup

serve: django-setup npm-install npm-serve django-serve

alias s := serve
